{
  "version": 2,
  "outputDirectory": "public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/privacy",  "dest": "/privacy.html" },
    { "src": "/(.*)",     "dest": "/$1"     }
  ],
  "crons": [
    {
      "path": "/api/notify",
      "schedule": "0 11 * * *"
    }
  ]
}
